{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx server.ts",
    "build:web": "vite build",
    "build:server": "esbuild server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs",
    "build": "npm run build:web && npm run build:server",
    "start": "node dist/server.cjs",
    "preview": "vite preview",
    "android:add": "cap add android",
    "android:sync": "npm run build:web && cap sync android",
    "android:open": "cap open android",
    "android:run": "npm run android:sync && cap run android",
    "android:build:debug": "npm run android:sync && cd android && gradlew assembleDebug",
    "firetv:sync": "npm run android:sync",
    "firetv:build:debug": "npm run android:build:debug",
    "clean": "rm -rf dist server.js",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@capacitor/android": "^8.3.4",
    "@capacitor/core": "^8.3.4",
    "@google/genai": "^1.29.0",
    "@tailwindcss/vite": "^4.1.14",
    "@tanstack/react-virtual": "^3.13.24",
    "@vitejs/plugin-react": "^5.0.4",
    "axios": "^1.16.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.2.1",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "hls.js": "^1.6.16",
    "iptv-playlist-parser": "^0.15.2",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "mpegts.js": "^1.8.0",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "react-window": "^2.2.7",
    "tailwind-merge": "^3.6.0",
    "vite": "^6.2.3",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.3.4",
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "esbuild": "^0.25.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3"
  }
}
